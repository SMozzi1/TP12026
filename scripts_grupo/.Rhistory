#primero agregamos la libreria tidyverse
library(tidyverse)
#Me "traigo" los datos que voy a usar
attach(datos)
#Filtramos los datos con el uso de mutate()
datos_limpios <- datos %>% #usamos la pipeline para asignar el resultado
# de una operacion
# nos quedamos con las columnas de interes
select(academia, sec_mng, tipo_academia_es, areas_mng, mng, ane) %>%
# nos quedamos solo con los paises con academias
filter(academia == "Sí")
# vemos los resultados finales
str(datos_limpios)
# Cargo los paquetes que voy a usar
library(tidyverse)
library(janitor)
# Fijo el dataset
attach(datos_limpios)
# Frecuencias
datos_limpios %>% group_by(tiempo) %>%
summarize(cant = n())
library(tidyverse)
library(janitor)
#me traigo los datos limpios
attach(datos_limpios)
tabla_academia <- datos_limpios %>%
tabyl(academia) %>%
adorn_totals("row")%>%
adorn_pct_formatting(digits = 1) %>%
rename("Presencia de Academia" = academia, "N" = n, "%" = percent)
tabla_leyes <- datos_limpios %>%
tabyl(sec_mng) %>%
adorn_totals("row") %>%
adorn_pct_formatting(difits = 1) %>%
rename("Nivel de Macros Normativos" = sec_mng, "N" = n, "%" = percent)
#table para variable de respuesta multiple
tabla_tipo_iniciativa <- datos_limpios %>%
tabyl(tipo_academia_es) %>%
arrange(desc(n)) %>%
adorn_pct_formatting(digits = 1)%>%
rename("Tipo de Iniciativa" = tipo_academia_es, "Frecuencia" = n, "% del total" = percent)
#vemos los datos
print(tabla_academia)
print(tabla_leyes)
print(tabla_tipo_iniciativa)
View(tabla_academia)
View(tabla_leyes)
View(tabla_tipo_iniciativa)
View(tabla_tipo_iniciativa)
# Adorns
tabla %>%
rename(   # Renombro columnas
"Especie" = especie,
"Cant. árboles" = n,
"% árboles" = percent
) %>%
adorn_totals() %>%  # Agrego fila de totales
adorn_pct_formatting(digits = 1) # Cant. de decimales en %
#paquetes que necesitamos
library(tidyverse)
library(ggplot2)
# me traigo los datos
attach(datos_limpios)
ggplot(datos_limpios,
aes(x = mng)) +
geom_histogram(
fill = "steelblue",
color = "black",
bins = 10
) +
labs(
title = "Distribucion del Puntaje de Macros Normativos",
x = "Puntaje (0 a 100)",
y = "Cantidad de Paises"
) +
theme_minimal()
ggplot(datos_limpios,
aes(x = ane)) +
geom_histogram(
fill = "steelblue",
color = "black",
bins = 10
) +
labs(
title = "Distribucion del Puntaje de Actores no estatales",
x = "Puntaje (0 a 100)",
y = "Cantidad de Paises"
) +
theme_minimal()
ggplot(datos_limpios,
aes(x = sec_mng)) +
geom_bar(
fill  = "coral",
color = "black",
width = 0.7
) +
labs(
title = "Nivel de Marcos Normativos",
x = "Nivel de Desarrollo",
y = "Cantidad de paises"
) +
theme_minimal()
ggplot(datos_limpios,
aes(x = sec_mng)) +
geom_bar(
fill  = "coral",
color = "black",
width = 0.7
) +
labs(
title = "Nivel de Marcos Normativos",
x = "Nivel de Desarrollo",
y = "Cantidad de paises"
) +
theme_minimal()
ggplot(datos_limpios,
aes(x = academia)) +
geom_bar(
fill  = "coral",
color = "black",
width = 0.7
) +
labs(
title = "Academia",
x = "Si",
y = "No"
) +
theme_minimal()

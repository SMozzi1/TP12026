library(googlesheets4)
# Link al archivo
url="https://docs.google.com/spreadsheets/d/1Kwl4KByOv8q2kXMsgaO3d5QI3vUQ40RCZJgJHhg5bmE/edit?usp=sharing"
# Evito loggeo
gs4_deauth()
# Leo el archivo y almaceno los datos en un data frame
datos <- read_sheet(url, sheet=2, skip = 1)
# Veo la estructura del dataset
str(datos)
View(datos)
#primero agregamos la libreria tidyverse
library(tidyverse)
#Me "traigo" los datos que voy a usar
attach(datos)
#Filtramos los datos con el uso de mutate()
datos_limpios <- datos %>% #usamos la pipeline para asignar el resultado
# de una operacion
# nos quedamos con las columnas de interes
select(academia, sec_mng, tipo_academia_es, areas_mng, mng, ane) %>%
# nos quedamos solo con los paises con academias
filter(acedmia == "Sí")
